<!DOCTYPE html>
<html>

<head>
    <meta http-equiv="Content-Type" content="text/html;charset=UTF-8">
    <title>Translate</title>
    <link rel="stylesheet" href="/styles/rtc.css">
</head>

<body>
    <section class="section-main-video">
        <div class="main-video-container">
            <!-- <span class="user-name">TEST</span>
            <video id="test" poster="/images/background3.jpg" src="/videos/2019_christmas.mp4" controls></video>
            <select name="" id=""></select> -->
        </div>
    </section>
    <section class="section-videos">
        <div class="local-video-container">
            <span id="local-user-name" class="user-name"></span>
            <video id="localVideo" autoplay muted></video>
        </div>
        <!-- <div class="video-container">
            <span class="user-name">TEST</span>
            <video id="test" poster="/images/background3.jpg" src="/videos/2019_christmas.mp4" controls></video>
            <select name="" id=""></select>
        </div> -->

    </section>
    <section class="local-config" style="display:block">
        <div class="local-config-container">
            <button class="config-icon" id="muteButton" onclick="toggleMute()"><img id="muteButtonImage"
                    src="/fonts/microphone.svg"></button>

            <div class="select">
                <select id="audioSource"></select>
            </div>

            <button class="config-icon" id="vidButton" onclick="toggleVid()"><img id="videoButtonImage"
                    src="/fonts/video.svg"></button>

            <div class="select">
                <select id="videoSource"></select>
            </div>
        </div>
    </section>
    <section class="info">
        <input type="hidden" id="info-user" value="<%=user%>"/>
    </section>
    <script lang="text/javascript" src="/socket.io/socket.io.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/simple-peer/9.9.3/simplepeer.min.js"
        integrity="sha512-0j8yvyjRIWuD9DD6gIKgQArBwURjNZoud+kvmcJC4zmxusqjnrHS7jwUZIBASfoZ00H5TAJJM5RH7RbxOU0iig=="
        crossorigin="anonymous"></script>
    <script src="https://webrtc.github.io/adapter/adapter-latest.js"></script>
    <script src='/js/main.js' async></script>
    <!-- <script src="/js/test.js"></script> -->
</body>

</html>